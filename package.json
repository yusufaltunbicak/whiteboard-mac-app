{
  "name": "whiteboard-mac-app",
  "version": "1.0.0",
  "productName": "Whiteboard Todos",
  "description": "Markdown-backed macOS whiteboard for todos.",
  "author": "Yusuf Altunbıçak",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "electron/main.js",
  "homepage": "https://github.com/yusufaltunbicak/whiteboard-mac-app#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yusufaltunbicak/whiteboard-mac-app.git"
  },
  "bugs": {
    "url": "https://github.com/yusufaltunbicak/whiteboard-mac-app/issues"
  },
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"node scripts/wait-for-vite.mjs\"",
    "build": "vite build",
    "run": "npm run build && WHITEBOARD_ELECTRON_LOAD=dist electron .",
    "package": "npm run build && electron-builder --dir -c electron-builder.config.cjs",
    "package:beta": "npm run build && electron-builder --dir -c electron-builder.beta.config.cjs",
    "dist": "npm run build && electron-builder -c electron-builder.config.cjs",
    "dist:beta": "npm run build && electron-builder -c electron-builder.beta.config.cjs",
    "dist:all": "npm run dist && npm run dist:beta",
    "publish:release": "npm run build && electron-builder -c electron-builder.config.cjs --publish always",
    "publish:beta": "npm run build && electron-builder -c electron-builder.beta.config.cjs --publish always",
    "test:parser": "node --test tests/markdown.test.mjs",
    "test:voice": "node --test tests/voice.test.mjs",
    "test:release-config": "node scripts/verify-release-config.cjs",
    "test:e2e": "npm run build && node tests/e2e-electron.mjs",
    "test:e2e:dev": "node tests/e2e-electron.mjs --dev",
    "start": "npm run run",
    "web:dev": "concurrently \"node server.js\" \"vite\"",
    "web:start": "NODE_ENV=production node server.js"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "electron-updater": "^6.8.3",
    "express": "^4.21.0",
    "gray-matter": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "playwright-core": "^1.60.0",
    "vite": "^5.4.0"
  }
}
